# Database Configuration
DATABASE_URL=your_postgresql_database_url_here

# Firebase Configuration
# Option 1: Use service account file path (recommended for development)
FIREBASE_SERVICE_ACCOUNT_PATH=./server/serviceAccountKey.json

# Option 2: Use environment variables (recommended for production)
# FIREBASE_PROJECT_ID=fornecedoranalise
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@fornecedoranalise.iam.gserviceaccount.com

# Firebase Database URL (if using Realtime Database)
FIREBASE_DATABASE_URL=https://fornecedoranalise-default-rtdb.firebaseio.com

# Other Environment Variables
NODE_ENV=development

# Pagar.me Configuration
PAGARME_PUBLIC_KEY=
PAGARME_SECRET_KEY=
